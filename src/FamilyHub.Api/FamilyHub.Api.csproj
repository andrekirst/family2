<Project Sdk="Microsoft.NET.Sdk.Web">

  <!-- Disable Hot Chocolate's auto-generated global usings (which include GreenDonut
       and its Result<T> that conflicts with our FamilyHub.Common.Application.Result<T>).
       We re-add HotChocolate and HotChocolate.Types explicitly without GreenDonut. -->
  <PropertyGroup>
    <HotChocolateImplicitUsings>disable</HotChocolateImplicitUsings>
  </PropertyGroup>
  <ItemGroup>
    <Using Include="HotChocolate" />
    <Using Include="HotChocolate.Types" />
    <Using Include="HotChocolate.Types.Relay" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="FamilyHub.Infisical.Tests" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Database\Migrations\**\*.sql" />
    <EmbeddedResource Include="Features\BaseData\Data\Seeds\federal-states.json" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="BCrypt.Net-Next" />
    <PackageReference Include="EFCore.NamingConventions" />
    <PackageReference Include="FluentValidation" />
    <PackageReference Include="FluentValidation.DependencyInjectionExtensions" />
    <PackageReference Include="HotChocolate.AspNetCore" />
    <PackageReference Include="HotChocolate.AspNetCore.Authorization" />
    <PackageReference Include="MetadataExtractor" />
    <PackageReference Include="Minio" />
    <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" />
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" />
    <PackageReference Include="dbup-postgresql" />
    <PackageReference Include="Microsoft.EntityFrameworkCore" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Relational" />
    <PackageReference Include="Npgsql.EntityFrameworkCore.PostgreSQL" />
    <PackageReference Include="Vogen" />
    <PackageReference Include="MailKit" />
    <PackageReference Include="Mediator.Abstractions" />
    <PackageReference Include="Mediator.SourceGenerator">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers</IncludeAssets>
    </PackageReference>
    <PackageReference Include="SixLabors.ImageSharp" />

    <!-- Event Bus (CAP + RabbitMQ) -->
    <PackageReference Include="DotNetCore.CAP" />
    <PackageReference Include="DotNetCore.CAP.PostgreSql" />
    <PackageReference Include="DotNetCore.CAP.RabbitMQ" />

    <!-- Background Jobs (Hangfire) -->
    <PackageReference Include="Hangfire.Core" />
    <PackageReference Include="Hangfire.AspNetCore" />
    <PackageReference Include="Hangfire.PostgreSql" />

    <!-- Resilience (Polly) -->
    <PackageReference Include="Microsoft.Extensions.Http.Resilience" />
    <PackageReference Include="Microsoft.Extensions.Resilience" />

    <!-- OpenTelemetry -->
    <PackageReference Include="OpenTelemetry.Exporter.OpenTelemetryProtocol" />
    <PackageReference Include="OpenTelemetry.Extensions.Hosting" />
    <PackageReference Include="OpenTelemetry.Instrumentation.AspNetCore" />
    <PackageReference Include="OpenTelemetry.Instrumentation.Http" />
    <PackageReference Include="OpenTelemetry.Instrumentation.EntityFrameworkCore" />

    <!-- Health Checks -->
    <PackageReference Include="AspNetCore.HealthChecks.NpgSql" />

    <!-- Security -->
    <PackageReference Include="NetEscapades.AspNetCore.SecurityHeaders" />
    <PackageReference Include="HtmlSanitizer" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\FamilyHub.Common\FamilyHub.Common.csproj" />
    <ProjectReference Include="..\FamilyHub.EventChain.Domain\FamilyHub.EventChain.Domain.csproj" />
    <ProjectReference Include="..\FamilyHub.EventChain.Infrastructure\FamilyHub.EventChain.Infrastructure.csproj" />
    <ProjectReference Include="..\FamilyHub.SourceGenerators\FamilyHub.SourceGenerators.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false" />
  </ItemGroup>

  <Target Name="CopyDevModule" AfterTargets="Build" Condition="'$(Configuration)' == 'Debug'">
    <Copy
      SourceFiles="$(MSBuildThisFileDirectory)..\FamilyHub.Dev\bin\Debug\$(TargetFramework)\FamilyHub.Dev.dll"
      DestinationFolder="$(OutputPath)"
      ContinueOnError="true" />
  </Target>

</Project>
